  "scripts": {
    "dev": "ladle serve",
    "build": "tsc -p tsconfig.build.json --emitDeclarationOnly && vite build && node scripts/postbuild.mjs",
    "build:stories": "ladle build",
    "build-storybook": "ladle build -o storybook-static",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ct": "playwright test -c playwright-ct.config.ts",
    "bench": "vitest bench --run",
    "perf": "node scripts/perf/run.mjs",
    "perf:update": "node scripts/perf/run.mjs --update",
    "size": "node scripts/perf/size.mjs",
    "size:update": "node scripts/perf/size.mjs --update",
    "audit": "npm audit --omit=dev --audit-level=high",
    "lint": "biome lint .",
    "format": "biome format --write .",
    "check": "biome check .",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test:ci": "vitest run",
    "prepublishOnly": "npm run check && npm run typecheck && npm run build"
  },
